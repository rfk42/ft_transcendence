POSTGRES_DB=ludo
POSTGRES_USER=ludo_user
POSTGRES_PASSWORD=change_me_db_password

DATABASE_URL=postgresql://ludo_user:change_me_db_password@localhost:5432/ludo

JWT_SECRET=change_me_long_random_string

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

FT_CLIENT_ID=your_42_client_id
FT_CLIENT_SECRET=your_42_client_secret

# Optional: set to true only when you need Prisma Studio for demo
ENABLE_PRISMA_STUDIO=true

# Credentials for HTTPS Basic Auth in front of Prisma Studio (https://localhost:5555).
PRISMA_STUDIO_USER=prisma
PRISMA_STUDIO_PASSWORD=mdp

# Optional: use a shared hostname for LAN access and OAuth callbacks.
# Example: ludo.local
LOCAL_HOSTNAME=ludo.local

# Optional overrides. Leave empty to let the backend rebuild URLs from the request host.
FRONTEND_URL=
GOOGLE_REDIRECT_URI=
FT_REDIRECT_URI=
