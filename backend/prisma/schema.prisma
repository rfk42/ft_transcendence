// Dis à Prisma qu'on utilise PostgreSQL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Génère automatiquement le client JavaScript
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

// TABLE USERS
model User {
  id             String    @id @default(uuid())
  email          String    @unique
  username       String    @unique
  passwordHash   String?
  
  // Infos de profil
  firstName      String?
  lastName       String?
  bio            String?   // Description courte du profil
  avatarUrl      String?   // URL de la photo de profil
  
  // Authentification
  googleId       String?   @unique  // OAuth Google
  fortyTwoId     String?   @unique  // OAuth 42
  twofaEnabled   Boolean   @default(false)
  twofaSecret    String?
  
  // Statut en ligne
  isOnline       Boolean   @default(false)
  lastSeenAt     DateTime  @default(now())
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  sentRequests     Friend[]           @relation("SentRequests")
  receivedRequests Friend[]           @relation("ReceivedRequests")
  gamePlayers      GamePlayer[]
  userStats        UserStats?         // Relation 1-1 avec statistiques
  gamesWon         Game[]             @relation("GameWinner")
}

// TABLE FRIENDS
model Friend {
  id        String   @id @default(uuid())
  status    String   @default("pending") // pending / accepted / blocked

  // Qui envoie la demande
  userId    String
  user      User     @relation("SentRequests", fields: [userId], references: [id], onDelete: Cascade)

  // Qui reçoit la demande
  friendId  String
  friend    User     @relation("ReceivedRequests", fields: [friendId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, friendId]) // on ne peut pas avoir deux fois la même paire
}

// TABLE GAMES (une partie de Ludo)
model Game {
  id          String   @id @default(uuid())
  status      String   @default("waiting") // waiting / playing / finished
  
  // Vainqueur
  winnerId    String?  // null tant que la partie n'est pas finie
  winner      User?    @relation("GameWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  finishedAt  DateTime?

  // Relations
  players     GamePlayer[]
  moves       GameMove[]
  matchHistory MatchHistory?
}

// TABLE GAME_PLAYERS (qui joue dans quelle partie)
model GamePlayer {
  id       String @id @default(uuid())
  color    String // "red" / "blue" / "green" / "yellow"
  position Int    @default(0) // position sur le plateau

  // Quel user
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dans quelle partie
  gameId   String
  game     Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])  // un user ne peut pas être deux fois dans la même partie
  @@unique([gameId, color])   // deux joueurs ne peuvent pas avoir la même couleur
}

// TABLE GAME_MOVES (historique des coups)
model GameMove {
  id         String   @id @default(uuid())
  diceValue  Int      // résultat du dé (1 à 6)
  pieceIndex Int      // quelle pièce a bougé (0 à 3)
  fromPos    Int      // position avant le coup
  toPos      Int      // position après le coup
  createdAt  DateTime @default(now())

  // Dans quelle partie
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

// TABLE USER_STATS (statistiques de jeu par user)
model UserStats {
  id              String   @id @default(uuid())
  
  // Statistiques générales
  totalGamesPlayed Int     @default(0)
  gamesWon        Int     @default(0)
  gamesLost       Int     @default(0)
  winRate         Float   @default(0) // pourcentage de victoires
  
  // Ranking et progression
  rank            Int?    // position dans le leaderboard
  
  // Stats détaillées
  totalMoves      Int     @default(0)
  averageGameDuration Int @default(0) // en secondes
  bestStreak      Int     @default(0) // plus belle série de victoires
  currentStreak   Int     @default(0) // série actuelle
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Lien avec l'utilisateur
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// TABLE MATCH_HISTORY (optionnel: historique détaillé des parties)
model MatchHistory {
  id             String   @id @default(uuid())
  gameId         String
  game           Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  // Infos des joueurs
  playersData    String   // JSON: [{userId, username, color, position, isWinner}, ...]
  
  // Statistiques de la partie
  duration       Int      // en secondes
  totalMoves     Int
  
  createdAt      DateTime @default(now())
  
  @@unique([gameId]) // une partie = un seul enregistrement dans match history
}